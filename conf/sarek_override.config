// ------------------------------------------------------------
// Resource overrides for upstream Sarek / heavy tools
// (No containers here — containers live in nextflow.config)
// ------------------------------------------------------------

process {

  withName: /.*(FASTQC|FASTP).*/ {
    cpus = 8; memory = '8 GB'; time = '4h'
  }
  
  withName: /.*(Merge(Sam|Bam)|MergeBamAlignment|GatherBamFiles).*/ {
    cpus = 12; memory = '30 GB'; time = '12h'
  }

  // BWA
  withName: /.*(BWA).*/ {
    cpus = 16; memory = '40 GB'; time = '24h'
  }

  // Generic merges
  withName: /.*(MERGE_BAM|MERGE_CRAM).*/ {
    cpus = 8; memory = '30 GB'; time = '12h'
  }

  // GATK family
  withName: /.*(GATK).*/ {
    cpus = 16; memory = '32 GB'; time = '24h'
  }
  
  withName: '.*GATK4_HAPLOTYPECALLER.*' {
        cpus = 8
        memory = { 48.GB * task.attempt }
        time = '24h'
        errorStrategy = { task.exitStatus in [125,137,140,143,50006] ? 'retry' : 'finish' }
        maxRetries = 3
    }

    // GetPileupSummaries — lightweight, doesn't need 16 threads, give it memory headroom instead
    //
    // ext.prefix is set explicitly here (mirroring external/sarek/conf/modules/mutect2.config)
    // rather than relying on Sarek's own `if (params.tools.contains('mutect2'))` config-parse-time
    // gate. That gate is evaluated when `includeConfig 'external/sarek/nextflow.config'` runs in
    // nextflow.config, which happens BEFORE BioVarFlow sets params.tools = "mutect2" for somatic
    // mode — so it's silently skipped and every interval chunk falls back to the same output name
    // ("<sample>.pileups.table"), causing an input file name collision when intervals are gathered.
    withName: '.*GETPILEUPSUMMARIES.*' {
        cpus = 4
        memory = { 40.GB * task.attempt }
        time = '12h'
        errorStrategy = { task.exitStatus in [125,137,140,143,50006] ? 'retry' : 'finish' }
        maxRetries = 3
        ext.prefix = { meta.num_intervals <= 1 ? "${meta.id}.mutect2" : "${meta.id}.mutect2.${intervals.baseName}" }
    }

    // GatherPileupSummaries — same reasoning as above; keeps output naming/publishDir consistent
    // with Sarek's expected variant_calling/mutect2/<sample>/ layout.
    withName: '.*GATHERPILEUPSUMMARIES.*' {
        ext.prefix = { "${meta.id}.mutect2" }
    }

  // DeepVariant
  withName: /.*(DEEPVARIANT).*/ {
    cpus = 16; memory = '60 GB'; time = '32h'
    maxForks = 4
  }

  // MultiQC
  withName: /.*(MULTIQC).*/ {
    cpus = 4; memory = '8 GB'; time = '4h'
  }

  // Indexing
  withName: /.*(SAMTOOLS_INDEX|BuildBamIndex|BamIndex|IndexBam|IndexFeatureFile).*/ {
    cpus = 8; memory = '4 GB'; time = '8h'
  }
  
  withName: /(?i)(BWA|MARKDUPLICATES|DEEPVARIANT|VEP|MOSDEPTH)/ {
    maxRetries = 4
  }
}

// ------------------------------------------------------------
// Resource overrides for upstream Sarek / heavy tools
// (No containers here — containers live in nextflow.config)
// ------------------------------------------------------------

process {

  withName: /.*(FASTQC|FASTP).*/ {
    cpus = 8; memory = '8 GB'; time = '4h'
  }
  
  withName: /.*(Merge(Sam|Bam)|MergeBamAlignment|GatherBamFiles).*/ {
    cpus = 12; memory = '30 GB'; time = '12h'
  }

  // BWA
  withName: /.*(BWA).*/ {
    cpus = 16; memory = '40 GB'; time = '24h'
  }

  // Generic merges
  withName: /.*(MERGE_BAM|MERGE_CRAM).*/ {
    cpus = 8; memory = '30 GB'; time = '12h'
  }

  // GATK family
  withName: /.*(GATK).*/ {
    cpus = 16; memory = '32 GB'; time = '24h'
  }
  
  withName: '.*GATK4_HAPLOTYPECALLER.*' {
        cpus = 8
        memory = { 48.GB * task.attempt }
        time = '24h'
        errorStrategy = { task.exitStatus in [125,137,140,143,50006] ? 'retry' : 'finish' }
        maxRetries = 3
    }

    // ------------------------------------------------------------------
    // MUTECT2 (somatic) directives, replicated from
    // external/sarek/conf/modules/mutect2.config
    //
    // That entire file wraps its ext.prefix/ext.args/publishDir directives in:
    //   if (params.tools && params.tools.split(',').contains('mutect2'))
    // which is evaluated at CONFIG-PARSE time, when `includeConfig
    // 'external/sarek/nextflow.config'` runs in nextflow.config — BEFORE
    // BioVarFlow sets params.tools = "mutect2" for somatic mode. So the
    // whole block is silently skipped. Consequences aren't just cosmetic:
    //   - MUTECT2_PAIRED loses its ext.args, which is the ONLY place
    //     `--normal-sample` gets passed to GATK Mutect2. Without it, Mutect2
    //     can't tell the germline sample apart from the tumor.
    //   - Every per-interval output (pileup tables, mutect2 stats/vcf) loses
    //     its interval-unique ext.prefix and falls back to the bare
    //     "<sample>.*" name, causing "input file name collision" errors
    //     once intervals are gathered/merged back together.
    // Repeated here, unconditionally, since this file loads AFTER Sarek's
    // own config and always wins regardless of that gate.
    // ------------------------------------------------------------------

    withName: 'GATK4_MUTECT2' {
        ext.args   = { params.ignore_soft_clipped_bases ? "--dont-use-soft-clipped-bases true --f1r2-tar-gz ${task.ext.prefix}.f1r2.tar.gz" : "--f1r2-tar-gz ${task.ext.prefix}.f1r2.tar.gz" }
        ext.prefix = { meta.num_intervals <= 1 ? "${meta.id}.mutect2" : "${meta.id}.mutect2.${intervals.baseName}" }
        ext.when   = { params.tools && params.tools.split(',').contains('mutect2') }
    }

    withName: 'MUTECT2_PAIRED' {
        cpus = 8
        memory = { 48.GB * task.attempt }
        time = '24h'
        errorStrategy = { task.exitStatus in [125,137,140,143,50006] ? 'retry' : 'finish' }
        maxRetries = 3
        ext.args = { params.ignore_soft_clipped_bases ?
                            "--dont-use-soft-clipped-bases true --f1r2-tar-gz ${task.ext.prefix}.f1r2.tar.gz --normal-sample ${meta.patient}_${meta.normal_id}" :
                            "--f1r2-tar-gz ${task.ext.prefix}.f1r2.tar.gz --normal-sample ${meta.patient}_${meta.normal_id}" }
    }

    withName: 'MERGE_MUTECT2.*' {
        ext.prefix = { "${meta.id}.mutect2" }
    }

    withName: 'FILTERMUTECTCALLS.*' {
        ext.prefix = { "${meta.id}.mutect2.filtered" }
    }

    withName: 'CALCULATECONTAMINATION' {
        ext.args   = { "-tumor-segmentation ${meta.id}.mutect2.segmentation.table" }
        ext.prefix = { "${meta.id}.mutect2" }
    }

    withName: 'LEARNREADORIENTATIONMODEL' {
        ext.prefix = { "${meta.id}.mutect2.artifactprior" }
    }

    withName: 'MERGEMUTECTSTATS' {
        ext.prefix = { "${meta.id}.mutect2" }
    }

    // GetPileupSummaries — lightweight, doesn't need 16 threads, give it memory headroom instead
    withName: '.*GETPILEUPSUMMARIES.*' {
        cpus = 4
        memory = { 40.GB * task.attempt }
        time = '12h'
        errorStrategy = { task.exitStatus in [125,137,140,143,50006] ? 'retry' : 'finish' }
        maxRetries = 3
        ext.prefix = { meta.num_intervals <= 1 ? "${meta.id}.mutect2" : "${meta.id}.mutect2.${intervals.baseName}" }
    }

    // GatherPileupSummaries — keeps output naming/publishDir consistent with
    // Sarek's expected variant_calling/mutect2/<sample>/ layout.
    withName: '.*GATHERPILEUPSUMMARIES.*' {
        ext.prefix = { "${meta.id}.mutect2" }
    }

  // DeepVariant
  withName: /.*(DEEPVARIANT).*/ {
    cpus = 16; memory = '60 GB'; time = '32h'
    maxForks = 4
  }

  // MultiQC
  withName: /.*(MULTIQC).*/ {
    cpus = 4; memory = '8 GB'; time = '4h'
  }

  // Indexing
  withName: /.*(SAMTOOLS_INDEX|BuildBamIndex|BamIndex|IndexBam|IndexFeatureFile).*/ {
    cpus = 8; memory = '4 GB'; time = '8h'
  }
  
  // Retry on transient infra failures (e.g. GCP Batch reclaiming/recreating the
  // VM mid-task, exit 50006) in addition to the usual OOM/SIGTERM codes — these
  // are long-running processes where losing a whole run to a spot-VM preemption
  // is expensive to redo.
  withName: /(?i)(BWA|MARKDUPLICATES|DEEPVARIANT|VEP|MOSDEPTH)/ {
    errorStrategy = { task.exitStatus in [125,137,140,143,50006] ? 'retry' : 'finish' }
    maxRetries = 4
  }
}
